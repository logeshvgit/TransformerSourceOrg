eight:700;color:#fff;margin:.3rem 0 .5rem}.jC-pr{font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;color:var(--j-lime)}.jC-d{font-size:.78rem;color:var(--j-dim);margin:.5rem 0 0;line-height:1.55}.jC-badge{position:absolute;top:1rem;right:1rem;font-family:'Orbitron',monospace;font-size:.5rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:rgba(255,64,129,.15);color:var(--j-pink);border:1px solid rgba(255,64,129,.3);border-radius:50px;padding:.2rem .6rem}/* ── KB CARDS ── */.jK{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:1.1rem}.jKc{background:var(--j-card);border:1px solid rgba(179,136,255,.1);border-radius:16px;padding:1.5rem;transition:transform .3s,box-shadow .3s}.jKc:hover{transform:translateY(-5px);box-shadow:var(--j-vglow)}.jKc-ic{font-size:2rem;margin-bottom:.6rem;display:block}.jKc-t{font-size:.9rem;font-weight:700;color:#fff;margin:0 0 .4rem}.jKc-s{font-size:.8rem;color:var(--j-dim);line-height:1.55}/* ── FORM ── */.jF{max-width:620px;margin:0 auto;background:linear-gradient(160deg,var(--j-card) 0%,rgba(17,22,51,.5) 100%);border:1px solid rgba(0,229,255,.1);border-radius:20px;padding:2.5rem;box-shadow:0 8px 40px rgba(0,0,0,.4)}.jF label{display:block;font-family:'Orbitron',monospace;font-size:.62rem;font-weight:700;color:var(--j-cyan);text-transform:uppercase;letter-spacing:.12em;margin-bottom:.3rem}.jF input,.jF select,.jF textarea{width:100%;padding:.7rem 1rem;background:rgba(255,255,255,.03);border:1px solid rgba(0,229,255,.12);border-radius:10px;color:var(--j-text);font-family:'Exo 2',sans-serif;font-size:.88rem;margin-bottom:1.1rem;transition:border-color .25s,box-shadow .25s}.jF input:focus,.jF select:focus,.jF textarea:focus{outline:none;border-color:var(--j-cyan);box-shadow:0 0 16px rgba(0,229,255,.12)}.jF textarea{min-height:110px;resize:vertical}.jF-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}@media(max-width:580px){.jF-row{grid-template-columns:1fr}}.jF-sub{display:block;width:100%;padding:.85rem;border:none;border-radius:50px;background:linear-gradient(135deg,var(--j-cyan),#0091ea);color:var(--j-void);font-family:'Orbitron',monospace;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;cursor:pointer;transition:box-shadow .3s,transform .3s}.jF-sub:hover{box-shadow:0 0 30px rgba(0,229,255,.45);transform:translateY(-2px)}/* ── FOOTER ── */.jFt{text-align:center;padding:2.5rem 2rem;color:var(--j-dim);font-size:.78rem;border-top:1px solid rgba(0,229,255,.08);background:var(--j-deep)}.jFt a{color:var(--j-cyan)}</style><div class=\"jP\"><!-- NAV --><nav class=\"jN\"><span class=\"jN-b\">&#9674; PRINTCO</span><ul class=\"jN-l\"><li><a href=\"#printers\">Printers</a></li><li><a href=\"#knowledge\">Knowledge</a></li><li><a href=\"#support\">Contact Support</a></li></ul></nav><!-- HERO --><section class=\"jH\"><div class=\"jH-stars\"><span style=\"top:8%;left:12%;--d:3.2s\"></span><span style=\"top:15%;left:78%;--d:4.5s\"></span><span style=\"top:25%;left:35%;--d:5.1s\"></span><span style=\"top:40%;left:90%;--d:3.8s\"></span><span style=\"top:55%;left:5%;--d:6s\"></span><span style=\"top:60%;left:60%;--d:2.8s\"></span><span style=\"top:72%;left:22%;--d:4.2s\"></span><span style=\"top:80%;left:85%;--d:5.5s\"></span><span style=\"top:10%;left:50%;--d:3s\"></span><span style=\"top:90%;left:45%;--d:4s\"></span><span style=\"top:35%;left:68%;--d:6.5s\"></span><span style=\"top:65%;left:40%;--d:3.5s\"></span><span style=\"top:48%;left:18%;--d:5.8s\"></span><span style=\"top:20%;left:92%;--d:4.8s\"></span><span style=\"top:75%;left:72%;--d:3.1s\"></span></div><div class=\"jH-ring jH-r1\"><span class=\"jH-dot\"></span></div><div class=\"jH-ring jH-r2\"><span class=\"jH-dot\" style=\"background:var(--j-violet);box-shadow:0 0 10px var(--j-violet)\"></span></div><div class=\"jH-ring jH-r3\"><span class=\"jH-dot\"></span></div><div class=\"jH-content\"><span class=\"jH-tag\">&#9733; Production &bull; Wide-Format &bull; Fleet &bull; Finishing</span><h1>The Future of Print Is Here</h1><p>Space-age precision meets production-grade reliability. PrintCo commercial printers deliver for the enterprises of tomorrow.</p><div class=\"jH-actions\"><a href=\"#printers\" class=\"jB jB-c\">&#9881; Explore printers</a><a href=\"#knowledge\" class=\"jB jB-v\">&#128218; Knowledge base</a><a href=\"#support\" class=\"jB jB-o\">&#9993; Contact support</a></div></div></section><!-- STATS --><div class=\"jSt\"><div class=\"jSt-i\"><div class=\"jSt-n\">100+</div><div class=\"jSt-l\">Pages per minute</div></div><div class=\"jSt-i\"><div class=\"jSt-n\">4hr</div><div class=\"jSt-l\">Gold SLA response</div></div><div class=\"jSt-i\"><div class=\"jSt-n\">36&quot;</div><div class=\"jSt-l\">Wide-format output</div></div><div class=\"jSt-i\"><div class=\"jSt-n\">10k+</div><div class=\"jSt-l\">Fleet devices managed</div></div></div><!-- PRINTERS --><div class=\"jDiv\"></div><section id=\"printers\" class=\"jS\"><h2 class=\"jS-t\"><span>Printer Lineup</span></h2><p class=\"jS-sub\">Commercial presses, fleet devices, finishing, supplies &amp; service plans</p><div class=\"jG\"><div class=\"jC\"><span class=\"jC-badge\">Flagship</span><div class=\"jC-sku\">PC-PRESS-5000</div><div class=\"jC-nm\">PrintCo Press 5000</div><div class=\"jC-pr\">$12,900</div><div class=\"jC-d\">High-volume production press &mdash; 100+ ppm, inline finishing, Fiery RIP ready.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-WIDE-36</div><div class=\"jC-nm\">Wide Format 36&quot;</div><div class=\"jC-pr\">$8,400</div><div class=\"jC-d\">Large-format inkjet for posters, banners, and architectural CAD drawings.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-COLOR-A3</div><div class=\"jC-nm\">Color Production A3</div><div class=\"jC-pr\">$5,200</div><div class=\"jC-d\">A3 color laser for mid-volume print rooms and in-plant operations.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-MONO-A4</div><div class=\"jC-nm\">Mono Fleet A4</div><div class=\"jC-pr\">$890</div><div class=\"jC-d\">Compact monochrome workhorse built for enterprise fleet deployments.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-FINISH-BOOK</div><div class=\"jC-nm\">Booklet Finisher Pro</div><div class=\"jC-pr\">$2,100</div><div class=\"jC-d\">Inline booklet maker &mdash; saddle stitch, fold, trim in a single pass.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-FIERY-RIP</div><div class=\"jC-nm\">Fiery RIP Module</div><div class=\"jC-pr\">$1,650</div><div class=\"jC-d\">Color management and prepress RIP engine for production presses.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-TONER-CMYK</div><div class=\"jC-nm\">Toner Set CMYK</div><div class=\"jC-pr\">$420</div><div class=\"jC-d\">Full CMYK cartridge set rated for production-class throughput.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-FUSER-KIT</div><div class=\"jC-nm\">Fuser Maintenance Kit</div><div class=\"jC-pr\">$310</div><div class=\"jC-d\">Replacement fuser assembly for scheduled preventive maintenance.</div></div><div class=\"jC\"><div class=\"jC-sku\">PC-MEDIA-GLOSS</div><div class=\"jC-nm\">Gloss Media Roll</div><div class=\"jC-pr\">$180</div><div class=\"jC-d\">Premium gloss roll media for wide-format photo and signage output.</div></div><div class=\"jC\"><span class=\"jC-badge\">Popular</span><div class=\"jC-sku\">PC-SLA-GOLD</div><div class=\"jC-nm\">Gold SLA Add-on</div><div class=\"jC-pr\">$2,400/yr</div><div class=\"jC-d\">4-hour onsite response, priority parts, and quarterly health checks.</div></div></div></section><!-- KNOWLEDGE --><div class=\"jDiv\"></div><section id=\"knowledge\" class=\"jS\"><h2 class=\"jS-t\"><span>Knowledge Base</span></h2><p class=\"jS-sub\">Self-service guides for your PrintCo devices</p><div class=\"jK\"><div class=\"jKc\"><span class=\"jKc-ic\">&#128196;</span><div class=\"jKc-t\">How to clear a paper jam on the PrintCo Press 5000</div><div class=\"jKc-s\">Step-by-step guide &mdash; front panel access, fuser area checks, diagnostics, and error code E-2041 escalation path.</div></div><div class=\"jKc\"><span class=\"jKc-ic\">&#128736;</span><div class=\"jKc-t\">Replacing toner cartridges on PrintCo color devices</div><div class=\"jKc-s\">CMYK cartridge swap for Color Production A3, Press 5000, and Wide Format 36&quot;. Includes reorder timing tips.</div></div><div class=\"jKc\"><span class=\"jKc-ic\">&#127912;</span><div class=\"jKc-t\">Configuring the Fiery RIP Module for color-accurate proofing</div><div class=\"jKc-s\">ICC profile setup, Pantone Plus import, spectrophotometer calibration, Delta-E thresholds for press quality.</div></div><div class=\"jKc\"><span class=\"jKc-ic\">&#128203;</span><div class=\"jKc-t\">PrintCo Gold SLA &mdash; coverage &amp; response times</div><div class=\"jKc-s\">4-hour onsite, priority overnight parts, quarterly PM, annual firmware upgrade, and exclusion details.</div></div></div></section><!-- CONTACT SUPPORT --><div class=\"jDiv\"></div><section id=\"support\" class=\"jS\"><h2 class=\"jS-t\"><span>Contact Support</span></h2><p class=\"jS-sub\">Submit a ticket &mdash; our team responds within one business day</p><div class=\"jF\"><form action=\"https://webto.salesforce.com/servlet/servlet.WebToCase?encoding=UTF-8&orgId=00DgL00000N396L\" method=\"POST\"><input type=\"hidden\" name=\"orgid\" value=\"00DgL00000N396L\"><input type=\"hidden\" name=\"retURL\" value=\"https://orgfarm-de3be1735c-dev-ed.develop.my.site.com/printcovforcesite\"><div class=\"jF-row\"><div><label>Your name</label><input name=\"name\" type=\"text\" placeholder=\"Jane Jetson\" required></div><div><label>Email</label><input name=\"email\" type=\"email\" placeholder=\"jane@spacely.com\" required></div></div><div class=\"jF-row\"><div><label>Company</label><input name=\"company\" type=\"text\" placeholder=\"Spacely Sprockets Inc.\"></div><div><label>Phone</label><input name=\"phone\" type=\"tel\" placeholder=\"+1 (555) 234-5678\"></div></div><label>S